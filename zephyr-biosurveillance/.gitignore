# Raw downloads and large/generated artifacts (regenerated by the scripts)
data/raw/*
!data/raw/.gitkeep

# Compressed sequence payloads (raw .gz downloads, kept-compressed pools, etc.)
data/raw_gz/*
!data/raw_gz/.gitkeep
*.gz
*.bgz

data/refs/*
!data/refs/.gitkeep
!data/refs/refs.tsv

# Alignment intermediates
results/bam/*
!results/bam/.gitkeep
results/paf/*
!results/paf/.gitkeep
results/coverage/*
!results/coverage/.gitkeep

# Figures (regenerated)
results/figures/*
!results/figures/.gitkeep

# Large per-read intermediate (one row per mapped read, ~100s of MB);
# regenerated by R/10_parse_taxonomy.R. Summary tables below are kept.
results/tables/read_hits.tsv

# Rendered memo (extended memo output)
memo/memo-extended.html
memo/memo-extended.docx
memo/memo-extended.pdf

# Conda/Miniforge installers (downloaded during setup, not part of the repo)
Miniforge3-*.sh
Miniconda3-*.sh

# R / editor cruft
.Rhistory
.RData
.Rproj.user/
*.fai
*.mmi
